generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  ownedFriends      FriendAccess[]   @relation("OwnerFriends")
  friendOf          FriendAccess[]   @relation("FriendMember")
  requests          BenefitRequest[]
}

model FriendAccess {
  id                String    @id @default(cuid())
  ownerId           String
  friendId          String
  nickname          String?
  activeUntil       DateTime?
  isDisabled        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  owner             User      @relation("OwnerFriends", fields: [ownerId], references: [id], onDelete: Cascade)
  friend            User      @relation("FriendMember", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([ownerId, friendId])
  @@index([friendId])
}

model Card {
  id                String        @id @default(cuid())
  name              String
  fcyFee            Decimal?      @db.Decimal(5, 2)
  isCredit          Boolean       @default(false)
  isDisabled        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  benefitLinks      BenefitCard[]
}

model Benefit {
  id                 String             @id @default(cuid())
  categoryName       String
  expiryDate         DateTime?
  cashbackType       CashbackType
  cashbackAmount     Decimal            @db.Decimal(12, 2)
  usageAvailable     Int?
  usageUsed          Int                @default(0)
  usageResetAt       DateTime?
  quotaResetsMonthly Boolean            @default(false)
  minimumSpending    Decimal?           @db.Decimal(12, 2)
  maximumSpending    Decimal?           @db.Decimal(12, 2)
  applicableWeekdays Weekday[]
  purchaseChannel    PurchaseChannel?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cardLinks          BenefitCard[]
  requests           BenefitRequest[]
}

model BenefitCard {
  id                String   @id @default(cuid())
  benefitId         String
  cardId            String
  benefit           Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  card              Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([benefitId, cardId])
}

model BenefitRequest {
  id                String            @id @default(cuid())
  userId            String
  benefitId         String
  amountSpent       Decimal           @db.Decimal(12, 2)
  purchaseChannel   PurchaseChannel
  status            RequestStatus     @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  benefit           Benefit           @relation(fields: [benefitId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
}

enum CashbackType {
  PERCENTAGE
  ONE_TIME_CASH
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PurchaseChannel {
  ONLINE_PURCHASE
  OFFLINE_PURCHASE
  FOREIGN_CURRENCY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
