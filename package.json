{
  "name": "jkpay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "start": "node scripts/run-next.mjs start",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --single-quote true --print-width 120 --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "postinstall": "prisma generate",
    "db:setup": "prisma migrate dev",
    "ncu": "npm-check-updates --reject @prisma/client,prisma,eslint",
    "ncu:upgrade": "npm-check-updates -u --reject @prisma/client,prisma,eslint"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.29",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
